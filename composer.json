{
    "name": "luminous-core/node-theme-tests",
    "description": "Dev-only test tooling for Node Utility plugins (PHPUnit + WP test suite). Not shipped in the theme/plugin ZIP.",
    "type": "project",
    "license": "MIT",
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0",
        "wp-phpunit/wp-phpunit": "^6.5"
    },
    "config": {
        "platform": {
            "php": "8.2"
        },
        "allow-plugins": {
            "composer/installers": true
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit -c phpunit.xml.dist"
    }
}
